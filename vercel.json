{
  "version": 2,
  "buildCommand": "bash ./build.sh",
  "builds": [
    {
      "src": "balon_dor/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "balon_dor/wsgi.py"
    }
  ]
}